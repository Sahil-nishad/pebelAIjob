{
  "manifest_version": 3,
  "name": "PebelAI Job Saver",
  "version": "0.1.0",
  "description": "Save job applications from any job board to your PebelAI account.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://pebelai.com/*",
    "https://www.pebelai.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PebelAI Job Saver",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
